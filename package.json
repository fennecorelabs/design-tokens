{
  "name": "@fennecorelabs/design-tokens",
  "version": "0.3.0",
  "description": "Shared design tokens, OKLCH theme system, and Design D (Organic Warm) aesthetic for the Adaptive AI ecosystem",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css/app-shell": "./css/app-shell.css",
    "./css/themes": "./css/themes.css",
    "./css/tokens": "./css/tokens.css",
    "./css/typography": "./css/typography.css",
    "./css/all": "./css/all.css",
    "./tailwind/preset": {
      "types": "./dist/tailwind/preset.d.ts",
      "import": "./dist/tailwind/preset.js"
    },
    "./components/ThemePicker": {
      "types": "./dist/components/ThemePicker.d.ts",
      "import": "./dist/components/ThemePicker.js"
    }
  },
  "files": [
    "css/",
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fennecorelabs/design-tokens.git"
  },
  "dependencies": {
    "@fennecorelabs/design-tokens": "^0.1.1"
  }
}
